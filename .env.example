# Copy this file to `.env` and fill in real values.

# Database connection string.
# Local dev (SQLite): file:./dev.db
# Production: SQLite needs a host with a PERSISTENT disk (Railway, Render, Fly.io
# with a volume, a VPS, etc.). On ephemeral serverless (Vercel/Netlify) switch the
# datasource to Postgres/Turso and use that connection string instead.
DATABASE_URL="file:./dev.db"

# Secret used to sign session JWTs. REQUIRED in production.
# Generate a strong random value, e.g.:  openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string"

# Public base URL of the deployed site (used for SEO/OG metadata).
NEXT_PUBLIC_SITE_URL="https://your-domain.com"
